# GlitchTip Database & App Configurations
GLITCHTIP_DB_PASSWORD=change_me_please
GLITCHTIP_SECRET_KEY=generate_a_random_long_string_here

# Umami Database & App Configurations
UMAMI_DB_PASSWORD=change_me_please
UMAMI_APP_SECRET=generate_another_random_long_string_here

# Frontend Application Tracking Configurations
# (To be updated once you retrieve your real DSN and Website ID from the running web interfaces)
GLITCHTIP_PUBLIC_KEY=your-glitchtip-public-key
UMAMI_WEBSITE_ID=your-umami-website-id-uuid-here

# Applications URLs (relative to the public access address)
GLITCHTIP_DOMAIN=http://localhost:8000
UMAMI_URL=http://localhost:3000
